{
  "_comment": "Example local MCP server settings for n8n workflow development.",
  "server": {
    "name": "n8n-workflow-library-mcp",
    "version": "0.1.0",
    "transport": "stdio",
    "logLevel": "info"
  },
  "tools": {
    "n8n_workflow_list": {
      "enabled": true,
      "rateLimitPerMinute": 30
    },
    "n8n_workflow_run": {
      "enabled": true,
      "rateLimitPerMinute": 10,
      "allowedWorkflowIds": ["wf_demo_lead_enrichment", "wf_demo_lead_intake"]
    },
    "n8n_credentials_create": {
      "enabled": false,
      "_note": "Credential creation is disabled by default."
    }
  },
  "auth": {
    "kind": "header",
    "headerName": "X-MCP-Auth",
    "tokenEnvVar": "MCP_SHARED_TOKEN"
  }
}
