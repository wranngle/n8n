{
  "_comment": "mcp.example.json — synthetic placeholder for the gitignored mcp.json. Copy to mcp.json (or .mcp.json depending on the agent runtime) and fill in real MCP server endpoints + tokens. The real file is gitignored because it contains API tokens for upstream MCP servers.",
  "mcpServers": {
    "n8n-mcp": {
      "command": "npx",
      "args": ["-y", "@example/n8n-mcp-server"],
      "env": {
        "N8N_API_URL": "https://n8n.example.com/api/v1",
        "N8N_API_KEY": "your-n8n-api-key-here"
      }
    },
    "elevenlabs-mcp": {
      "command": "npx",
      "args": ["-y", "@example/elevenlabs-mcp"],
      "env": {
        "ELEVENLABS_API_KEY": "your-elevenlabs-api-key-here"
      }
    },
    "twilio-mcp": {
      "command": "npx",
      "args": ["-y", "@example/twilio-mcp"],
      "env": {
        "TWILIO_ACCOUNT_SID": "AC00000000000000000000000000000000",
        "TWILIO_AUTH_TOKEN": "your-twilio-auth-token-here"
      }
    }
  }
}
