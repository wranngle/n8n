{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "description": "Maps n8n node types to Hierarchical Sequential Development levels",
  "version": "1.0.0",
  "levelMappings": {
    "3": {
      "description": "Node/Component level - Individual workflow nodes",
      "nodeTypes": [
        "n8n-nodes-base.httpRequest",
        "n8n-nodes-base.code",
        "n8n-nodes-base.function",
        "n8n-nodes-base.functionItem",
        "n8n-nodes-base.set",
        "n8n-nodes-base.if",
        "n8n-nodes-base.switch",
        "n8n-nodes-base.merge",
        "n8n-nodes-base.splitInBatches",
        "n8n-nodes-base.wait",
        "n8n-nodes-base.noOp",
        "n8n-nodes-base.respondToWebhook",
        "n8n-nodes-base.executeCommand",
        "n8n-nodes-base.readBinaryFile",
        "n8n-nodes-base.writeBinaryFile",
        "n8n-nodes-base.crypto",
        "n8n-nodes-base.dateTime",
        "n8n-nodes-base.xml",
        "n8n-nodes-base.html",
        "n8n-nodes-base.markdown",
        "n8n-nodes-base.compression",
        "n8n-nodes-base.itemLists",
        "n8n-nodes-base.summarize",
        "n8n-nodes-base.aggregate",
        "n8n-nodes-base.removeDuplicates",
        "n8n-nodes-base.sort",
        "n8n-nodes-base.limit",
        "n8n-nodes-base.filter",
        "@n8n/n8n-nodes-langchain.lmChatGoogleGemini",
        "@n8n/n8n-nodes-langchain.lmChatOpenAi",
        "@n8n/n8n-nodes-langchain.lmChatAnthropic",
        "@n8n/n8n-nodes-langchain.agent",
        "@n8n/n8n-nodes-langchain.chainLlm",
        "@n8n/n8n-nodes-langchain.chainSummarization",
        "@n8n/n8n-nodes-langchain.chainRetrievalQa"
      ],
      "testingStrategy": "Node isolation tests with mock credentials and sample input data",
      "mockRequirements": {
        "inputItems": true,
        "credentials": "mocked",
        "parameters": true
      }
    },
    "5": {
      "description": "Usage/Implementation level - Subworkflow executions and triggers",
      "nodeTypes": [
        "n8n-nodes-base.executeWorkflow",
        "n8n-nodes-base.executeWorkflowTrigger",
        "n8n-nodes-base.errorTrigger",
        "n8n-nodes-base.start"
      ],
      "testingStrategy": "Integration tests verifying subworkflow I/O contracts",
      "mockRequirements": {
        "subworkflowId": true,
        "inputData": true,
        "outputValidation": true
      }
    },
    "6": {
      "description": "Orchestration level - Trigger nodes that start workflows",
      "nodeTypes": [
        "n8n-nodes-base.webhook",
        "n8n-nodes-base.manualTrigger",
        "n8n-nodes-base.scheduleTrigger",
        "n8n-nodes-base.emailTrigger",
        "n8n-nodes-base.formTrigger",
        "n8n-nodes-base.chatTrigger",
        "n8n-nodes-base.sseWrite",
        "n8n-nodes-base.workflowTrigger"
      ],
      "testingStrategy": "End-to-end workflow tests with simulated trigger events",
      "mockRequirements": {
        "triggerEvent": true,
        "fullPipelineExecution": true,
        "externalServiceMocks": true
      }
    }
  },
  "integrationServices": {
    "description": "External service integrations - mapped to Node/Component level (3)",
    "level": 3,
    "categories": {
      "communication": [
        "n8n-nodes-base.slack",
        "n8n-nodes-base.discord",
        "n8n-nodes-base.telegram",
        "n8n-nodes-base.twilio",
        "n8n-nodes-base.sendGrid",
        "n8n-nodes-base.mailchimp"
      ],
      "crm": [
        "n8n-nodes-base.hubspot",
        "n8n-nodes-base.salesforce",
        "n8n-nodes-base.pipedrive",
        "n8n-nodes-base.zoho"
      ],
      "database": [
        "n8n-nodes-base.postgres",
        "n8n-nodes-base.mysql",
        "n8n-nodes-base.mongodb",
        "n8n-nodes-base.redis",
        "n8n-nodes-base.elasticsearch"
      ],
      "storage": [
        "n8n-nodes-base.googleDrive",
        "n8n-nodes-base.dropbox",
        "n8n-nodes-base.s3",
        "n8n-nodes-base.ftp"
      ],
      "ai": [
        "n8n-nodes-base.openAi",
        "@n8n/n8n-nodes-langchain.*"
      ],
      "productivity": [
        "n8n-nodes-base.googleSheets",
        "n8n-nodes-base.notion",
        "n8n-nodes-base.airtable",
        "n8n-nodes-base.asana",
        "n8n-nodes-base.trello",
        "n8n-nodes-base.jira"
      ]
    },
    "testingStrategy": "API response mocking with recorded fixtures"
  },
  "verificationRequirements": {
    "nodeLevel": {
      "RUNTIME": "Node executes without errors with test credentials",
      "MOCKED": "Node produces expected output with mock input data",
      "INTEGRATED": "Node works correctly in workflow context",
      "VERIFIED": "Node handles real external service responses"
    },
    "workflowLevel": {
      "RUNTIME": "Workflow loads and validates without errors",
      "MOCKED": "Workflow executes with all nodes mocked",
      "INTEGRATED": "Workflow executes with some real nodes",
      "VERIFIED": "Workflow executes fully with production data"
    }
  },
  "mockDataTemplates": {
    "httpRequest": {
      "input": { "url": "https://api.example.com/test", "method": "GET" },
      "output": { "statusCode": 200, "body": { "success": true } }
    },
    "code": {
      "input": { "items": [{ "json": { "test": true } }] },
      "output": { "items": [{ "json": { "processed": true } }] }
    },
    "webhook": {
      "input": { "headers": {}, "body": { "event": "test" }, "query": {} },
      "output": { "items": [{ "json": { "event": "test" } }] }
    },
    "executeWorkflow": {
      "input": { "workflowId": "test-workflow", "data": {} },
      "output": { "items": [{ "json": { "subworkflowResult": true } }] }
    }
  }
}
