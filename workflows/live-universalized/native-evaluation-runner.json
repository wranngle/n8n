    {
      "parameters": {
        "jsCode": "// Parse test results and determine pass/fail\nconst testPayload = $('Prepare Test Payload').item.json;\nconst results = $input.first().json;\n\n// Check if test passed\nlet passed = false;\nlet score = 0;\nlet details = 'No results';\n\nif (results && results.status) {\n  if (results.status === 'completed') {\n    passed = results.passed === true;\n    score = passed ? 100 : 0;\n    details = results.evaluation_result || 'Completed';\n  } else if (results.status === 'running') {\n    details = 'Test still running';\n  } else {\n    details = `Status: ${results.status}`;\n  }\n}\n\nreturn [{\n  json: {\n    test_name: testPayload.test_name,\n    category: testPayload.category,\n    result: passed ? 'pass' : 'fail',\n    score: score,\n    details: details,\n    raw_results: results,\n    evaluated_at: new Date().toISOString()\n  }\n}];"
      },
      "id": "evaluate-result",
      "name": "Transform: Evaluate Result",
