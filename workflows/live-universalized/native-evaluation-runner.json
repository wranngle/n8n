    {
      "parameters": {
        "jsCode": "// Prepare ElevenLabs test payload from Data Table row\nconst item = $input.first();\nconst testData = item.json;\n\n// Extract test case data\nconst testName = testData.test_name || 'Unknown Test';\nlet chatHistory = [];\ntry {\n  const rawHistory = typeof testData.chat_history === 'string' \n    ? JSON.parse(testData.chat_history) \n    : testData.chat_history || [];\n  // Ensure each entry has required fields\n  chatHistory = rawHistory.map((entry, idx) => ({\n    role: entry.role || 'user',\n    message: entry.message || entry.content || 'Hello',\n    time_in_call_secs: entry.time_in_call_secs ?? idx\n  }));\n} catch(e) {\n  chatHistory = [{role: 'user', message: 'Hello', time_in_call_secs: 0}];\n}\n\nconst successCondition = testData.success_condition || 'Agent responds appropriately';\nconst testType = testData.test_type || 'llm';\nconst agentId = testData.agent_id || 'agent_8001kdgp7qbyf4wvhs540be78vew';\n\n// Build API payload with correct format per ElevenLabs API docs\n// success_examples and failure_examples must be arrays of {response, type} objects\nreturn [{\n  json: {\n    test_name: testName,\n    test_type: testType,\n    category: testData.category || 'general',\n    agent_id: agentId,\n    api_payload: {\n      name: testName,\n      type: testType,\n      chat_history: chatHistory,\n      success_condition: successCondition,\n      success_examples: [\n        { response: 'Agent correctly follows the expected behavior', type: 'success' }\n      ],\n      failure_examples: [\n        { response: 'Agent fails to follow expected behavior', type: 'failure' }\n      ]\n    }\n  }\n}];"
      },
      "id": "prepare-payload",
      "name": "Transform: Prepare Test Payload",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        224,
        0
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.elevenlabs.io/v1/convai/agent-testing/create",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify($json.api_payload) }}",
        "options": {}
      },
      "id": "create-test",
      "name": "HTTP: Create Test In Eleven Labs",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
