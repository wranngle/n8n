      ],
      "parameters": {
        "jsCode": "// Score the workflow execution\nconst config = $('Set Target Workflow').first().json;\nconst result = $input.first().json;\n\nlet score = 0;\nlet details = [];\n\n// Check if execution succeeded\nif (result) {\n  score += 50;\n  details.push('✓ Workflow executed successfully');\n  \n  // Check for expected response fields\n  const resultStr = JSON.stringify(result);\n  if (resultStr.includes('agent_id')) {\n    score += 25;\n    details.push('✓ Contains agent_id');\n  }\n  if (resultStr.includes('name')) {\n    score += 25;\n    details.push('✓ Contains name field');\n  }\n} else {\n  details.push('✗ Workflow execution failed or returned empty');\n}\n\nreturn {\n  workflow_id: config.target_workflow_id,\n  workflow_name: config.target_name,\n  evaluation_id: `eval_${Date.now()}`,\n  completed_at: new Date().toISOString(),\n  score: score,\n  passed: score >= 70,\n  status: score >= 70 ? 'PASS' : 'NEEDS_IMPROVEMENT',\n  details: details,\n  raw_result: result\n};"
      }
    }
  ],
