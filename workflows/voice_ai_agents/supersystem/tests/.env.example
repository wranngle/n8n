# ElevenLabs Agent Test Framework - Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env files with real credentials!

# Required: ElevenLabs API Key
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# Optional: Agent configuration
ELEVENLABS_AGENT_ID=agent_8001kdgp7qbyf4wvhs540be78vew
ELEVENLABS_SIM_MODEL=gemini-3-flash-preview

# Optional: Supersystem webhook base URL
SUPERSYSTEM_BASE=https://n8n.wranngle.com/webhook

# Optional: Test execution parameters
BATCH_SIZE=5
MAX_CYCLES=10
DELAY_BETWEEN_SIMS_MS=3000

# Optional: Network configuration
REQUEST_TIMEOUT_MS=30000
MAX_RETRIES=3
BASE_RETRY_DELAY_MS=1000

# Optional: n8n API (for Layer 8 evaluations)
N8N_API_KEY=your_n8n_api_key_here
N8N_BASE_URL=https://n8n.wranngle.com

# Optional: Debug mode (shows parse errors, verbose logging)
DEBUG=false
