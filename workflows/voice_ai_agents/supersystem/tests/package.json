{
  "name": "elevenlabs-agent-tests",
  "version": "1.1.0",
  "description": "Multi-layer test framework for ElevenLabs voice agents",
  "main": "airtight-orchestrator.js",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "test": "node airtight-orchestrator.js",
    "test:parallel": "node airtight-orchestrator.js --parallel",
    "test:layer7": "node airtight-orchestrator.js --skip-engine --skip-n8n",
    "test:layer8": "node airtight-orchestrator.js --skip-engine --skip-elevenlabs",
    "test:engine": "node airtight-orchestrator.js --skip-elevenlabs --skip-n8n",
    "ultrathink": "node ultrathink-engine.js",
    "create-tests": "node layer7-elevenlabs-tests.js create",
    "run-tests": "node layer7-elevenlabs-tests.js run",
    "validate": "node -c airtight-orchestrator.js && node -c layer7-elevenlabs-tests.js && node -c ultrathink-engine.js"
  },
  "dependencies": {
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "c8": "^9.1.0"
  },
  "keywords": [
    "elevenlabs",
    "voice-agents",
    "testing",
    "n8n",
    "automation"
  ],
  "author": "Wranngle",
  "license": "MIT",
  "repository": {
    "type": "git",
    "directory": "workflows/voice_ai_agents/supersystem/tests"
  }
}
