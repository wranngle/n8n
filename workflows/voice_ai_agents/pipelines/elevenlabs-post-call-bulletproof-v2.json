            {
              "name": "crm_skip_reason",
              "value": "={{ $json.config.ENABLE_CRM ? 'No valid pipedrive_person_id' : 'CRM disabled in config' }}",
              "type": "string"
            },
            {
              "name": "crm_updated",
              "value": false,
              "type": "boolean"
            }
          ]
        },
        "includeOtherFields": true
