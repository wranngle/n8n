      "typeVersion": 1,
      "position": [
        1320,
        200
      ],
      "parameters": {
        "resource": "note",
        "operation": "create",
        "content": "={{ $json.crm_note_content }}",
        "additionalFields": {
          "person_id": "={{ $json.pipedrive_person_id }}"
        }
      },
      "credentials": {
        "pipedriveApi": {
          "id": "wranngle-pipedrive",
          "name": "Wranngle Pipedrive"
        }
      },
      "retryOnFail": true,
      "maxTries": 3,
      "waitBetweenTries": 2000,
      "continueOnFail": true
    },
    {
      "id": "skip-crm",
      "name": "Skip CRM",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [
        1100,
        400
      ],
      "parameters": {
        "mode": "manual",
        "assignments": {
