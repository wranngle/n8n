# n8n - Environment Configuration
# Copy this file to .env and fill in your values.
# Helper scripts also read ~/.agents/.env (process.env wins on conflict;
# see scripts/lib/env.js and scripts/lib/env.py).

# ===================================
# n8n API access
# ===================================

# X-N8N-API-KEY header value. Required by every script under scripts/ that
# talks to the n8n REST API (list_workflows, update_workflow, governance,
# create-twilio-cred, etc.).
N8N_API_KEY=

# n8n base URL. Note: scripts in this repo currently hardcode
# https://n8n.wranngle.com — this var is reserved for forthcoming scripts
# that read it from env. Override here if you point at a non-prod instance.
N8N_API_URL=

# ===================================
# Webhook authentication
# ===================================

# Shared secret sent as the X-Webhook-Secret header by every n8n webhook
# caller in this repo. The value MUST match the credential bound to each
# n8n webhook node. See docs/WEBHOOK_AUTH.md for the rotation playbook.
N8N_WEBHOOK_SECRET=

# Existing n8n credential ID to reuse for X-Webhook-Secret bindings instead
# of provisioning a new credential. Consumed by scripts/secure-n8n-webhooks.js
# and scripts/secure-internal-callers.js.
N8N_WEBHOOK_AUTH_CRED_ID=

# ===================================
# Twilio (credential provisioning)
# ===================================

# Used by scripts/create-twilio-cred.js to mint an n8n Twilio credential.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# ===================================
# Clay (referenced inside workflow JSON)
# ===================================

# Clay API key — referenced as {{ $env.CLAY_API_KEY }} inside the
# lead-enrichment-microservice workflow node, expected to be set on the
# n8n runtime, not on local script invocations.
CLAY_API_KEY=
