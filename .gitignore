# n8n Workflow Development - Git Ignore

# ===================
# CREDENTIALS & SECRETS
# ===================
# NEVER commit these
.env
.env.local
.env.*.local
credentials*.json
secrets*.json
**/credentials/**
**/secrets/**
*.key
*.pem

# BUT DO commit example files
!.env.example
!config/mcp-credentials.example.env

